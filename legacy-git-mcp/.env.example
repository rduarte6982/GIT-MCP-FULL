# ===== OBRIGATORIO =====
# GitHub Personal Access Token (classic ou fine-grained)
# https://github.com/settings/tokens
# Escopos para "plenos poderes": repo, read:org, read:user, user:email, gist, notifications, workflow, read:packages
GITHUB_TOKEN=ghp_seu_token_aqui

# ===== TRANSPORT =====
# stdio (padrao, para Claude Code/Desktop local) ou http (para deploy remoto / claude.ai)
MCP_TRANSPORT=stdio

# ===== APENAS QUANDO MCP_TRANSPORT=http =====
PORT=3000
# Bearer token que o cliente MCP precisa enviar em Authorization: Bearer <token>
# Gere com: openssl rand -hex 32
MCP_AUTH_TOKEN=

# ===== OPCIONAL =====
# GitHub Enterprise Server URL (deixe vazio para github.com)
# GITHUB_API_URL=https://github.minha-empresa.com/api/v3
